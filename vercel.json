{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/gemini/ugc-worker.ts": {
      "maxDuration": 60
    },
    "api/gemini/seedream-worker.ts": {
      "maxDuration": 90
    },
    "api/avatar/clone-worker.ts": {
      "maxDuration": 300
    },
    "api/webhooks/lemonsqueezy.ts": {
      "maxDuration": 10
    },
    "api/**/*.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}